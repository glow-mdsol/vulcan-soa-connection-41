# Per-machine dev-server ports, loaded by the Taskfile (dotenv) for every task.
# Copy to .env (gitignored) and adjust when the defaults collide with other
# apps on your machine. Shell env vars still win over these values.
#
# If you change BACKEND_PORT: set REDIRECT_URI in backend/.env.local to match
# and re-register the client (task aidbox:register-client -- --apply).
# If you change FRONTEND_PORT: set FRONTEND_URL in backend/.env.local to match.
FRONTEND_PORT=5173
BACKEND_PORT=8000
