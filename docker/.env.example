# =============================================================================
# docker/.env — local Aidbox instance environment
# =============================================================================
# 1. Copy to docker/.env (never commit the real .env):
#      cp docker/.env.example docker/.env
#
# 2. Fill in AIDBOX_LICENSE from https://aidbox.app
#    (sign in → your project → Licenses → Create license → copy the key)
#
# 3. If you change SMART_CLIENT_SECRET here, also update it in
#    backend/.env.local (SMART_CLIENT_SECRET= line) and restart both.
# =============================================================================

# Required: your Aidbox license key
AIDBOX_LICENSE=

# Aidbox admin UI password  (http://localhost:8888  →  admin / <this>)
AIDBOX_ADMIN_PASSWORD=admin

# SMART confidential client secret — must match backend/.env.local
SMART_CLIENT_SECRET=change-me

# Internal Postgres password (no need to change for local dev)
POSTGRES_PASSWORD=aidbox-local-pw
